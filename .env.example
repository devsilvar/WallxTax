# =================================
# Frontend env vars (Vite)
# =================================
# Only variables prefixed VITE_ are exposed to client-side code.
# Set these in your deploy host's dashboard (Vercel / Netlify), NOT in git.

# API base URL.
#   Dev: leave UNSET — falls back to '/api/v1' which Vite proxies to
#        the local backend (see vite.config.ts).
#   Prod: full URL including /api/v1 path prefix.
VITE_API_BASE_URL=http://localhost:3000/api/v1
